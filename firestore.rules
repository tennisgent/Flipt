rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Games: any authenticated user can read; only participants can write
    match /games/{gameId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid;
      // Allow joining a game that's still waiting, or updating if you're
      // already a participant or the host
      allow update: if request.auth != null
        && (resource.data.status == "waiting"
            || request.auth.uid in resource.data.players
            || request.auth.uid == resource.data.hostUid);
    }

    // Rounds: any authenticated user can read and create; participants can update
    match /rounds/{roundId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Round results: players can create their own; anyone in the game can read
    match /round-results/{resultId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.playerUid == request.auth.uid;
    }
  }
}
